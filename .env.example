# Mandarly OSS environment template
#
# Copy to .env.local and fill values for local development only.
# Never commit real credentials, production hosts, customer data, or cloud account IDs.

# Local app origins
APP_BASE_URL=http://localhost:3001
ADMIN_BASE_URL=http://localhost:5666
SERVER_BASE_URL=http://localhost:48080

# Database and cache
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=mandarly
MYSQL_USERNAME=root
MYSQL_PASSWORD=change_me
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=

# Object storage placeholders
S3_REGION=local
S3_BUCKET=mandarly-dev
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Classroom integration placeholders
CLASSROOM_MODE=mock
CLASSROOM_APP_ID=
CLASSROOM_SECRET=
CLASSROOM_CALLBACK_KEY=

# SMS provider placeholders
SMS_PROVIDER=mock
SMS_APP_ID=
SMS_APP_KEY=
SMS_REGION=

# Email placeholders
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Mandarly

# Payment placeholders
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth placeholders
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback/google

# PII encryption placeholder
MANDARLY_PII_AES_KEY=
